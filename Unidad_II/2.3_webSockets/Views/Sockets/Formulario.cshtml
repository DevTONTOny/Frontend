<input type="text" id="txtNombre" />
<input type="text" id="txtLat" />
<input type="text" id="txtLon" />
<button id="btnEnviar">Enviar usuario</button>
<script src=https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/9.0.6/signalr.min.js></script>
<script>
    const conexion = new signalR.HubConnectionBuilder()
        .withUrl("/MapacheWebSocketServer")
        .build();

    conexion.start().then(function (e) {
        console.log("Conectado");
    }).catch((e) => {
        console.log("Error al conectarse");
        console.log(e);
    });
    async function EnviarUsiaro(){
        const response = await fetch('https://randomuser.me/api/');
        const data = await response.json();
        const persona = data.results[0];
        const lat = persona.location.coordinates.latitude;
        const nombre = persona.name.first + " " + persona.name.last;
        const lon = persona.location.coordinates.longitude;
        const genero = persona.gender;
        conexion.invoke("SendUsuario", nombre, parseFloat(lat), parseFloat(lon));
        
        console.log("Enviado");
        console.log(data.results[0]);
        if(genero == "female"){
            console.log("mujer");
            conexion.invoke("sendGender", 2);
        }else{
            console.log("hombre")
            conexion.invoke("sendGender", 1);
        }
    }
    btnEnviar.addEventListener("click", () => {
        EnviarUsiaro();
        console.log("click");
    })

</script>